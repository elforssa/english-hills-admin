# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is listed in .gitignore.
#
# NEXT_PUBLIC_*  → exposed to the browser bundle. Safe-to-leak values only.
# everything else → server-side only (API routes, server components).
#
# Edge Function secrets (RESEND_API_KEY etc inside supabase/functions/) live
# in a separate place — set them with `supabase secrets set <name>=...`.
# This file does NOT push to the Edge Function runtime.
# =============================================================================

# ─── Supabase (public; embedded in browser bundle) ───────────────────────────
# Project URL. Shape: https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co

# Anonymous key — designed to be public. Pair with RLS policies for security.
# Get from Supabase dashboard → Settings → API → Project API keys → anon/public
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<your-anon-key>

# ─── Resend (server only — used by /api/email/send) ──────────────────────────
# Personal Resend API key. Create at https://resend.com/api-keys.
# Format: re_<48 chars>. Required for the /api/email/send route to work.
RESEND_API_KEY=re_<your-resend-key>

# Verified sender. Resend rejects sends from unverified domains.
# Until you verify your own domain you can use the Resend test sender:
#   English Hills <onboarding@resend.dev>  (only sends to your Resend account email)
RESEND_FROM_ADDRESS=English Hills <noreply@your-domain.com>

# ─── Supabase service-role key (server only) ─────────────────────────────────
# Required for /api/admin/invite and /api/admin/update-role.
# Treat as a password — do NOT commit. Never expose to the browser.
# Get from Supabase dashboard → Settings → API → Project API keys → service_role.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<your-service-role-key>
