# =============================================================================
# Environment variable template. Copy to .env.local and fill in real values.
# =============================================================================

# Supabase — public values, safe in browser
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Resend — server only. Powers /api/email/send and the receipt Edge Function.
# Note: the Edge Function reads its OWN copy of these via `supabase secrets set`.
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=English Hills <noreply@english-hills.com>

# Supabase service-role key — server only, NEVER commit. Used by admin routes.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
