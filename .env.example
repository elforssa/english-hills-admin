# =============================================================================
# Environment variable template. Copy to .env.local and fill in real values.
# =============================================================================

# Supabase — public values, safe in browser
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Resend — server only. Powers /api/email/send and the receipt Edge Function.
# Note: the Edge Function reads its OWN copy of these via `supabase secrets set`.
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=English Hills <noreply@english-hills.com>

# Supabase service-role key — server only, NEVER commit. Used by admin routes.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Cloudflare Turnstile — public signup CAPTCHA on /inscription.
# Site key is rendered in the browser; secret is used by
# /api/public/inscription to verify the user's token via Cloudflare's
# siteverify endpoint. If TURNSTILE_SECRET_KEY is unset the gate is
# bypassed (handy for local dev) — set it in production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAA...

# Edge Function shared secret — Supabase signs webhook calls to
# sendReceiptEmail with the service-role key. Set this to the same value
# via:  supabase secrets set FUNCTION_AUTH_TOKEN=$(grep service_role .env.local | cut -d= -f2)
# If unset, the function falls back to checking SUPABASE_SERVICE_ROLE_KEY.
# (Configured per-function in Supabase, not in this file — listed for
# completeness.)

# ─── Sentry (error monitoring) ───────────────────────────────────────────────
# Inert until NEXT_PUBLIC_SENTRY_DSN is set. Create an EU-region project at
# https://sentry.io (Settings → Projects → choose EU data region) for CNDP.
# DSN is safe to expose in the browser. Mirror these in Vercel project settings.
NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.de.sentry.io/<project>
# Build-time source-map upload (CI/Vercel only — keep out of local dev):
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=english-hills-admin
SENTRY_AUTH_TOKEN=sntrys_<token>
